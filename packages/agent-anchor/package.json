{
  "name": "adp-agent-anchor",
  "version": "0.1.0",
  "description": "Neo3 blockchain anchor for ADP calibration snapshots. Optional extension to adp-agent that periodically commits signed calibration snapshots to a Neo3-compatible chain.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "keywords": [
    "adp",
    "calibration-anchor",
    "neo3",
    "blockchain",
    "tamper-evidence"
  ],
  "license": "CC0-1.0",
  "homepage": "https://adp-manifest.dev",
  "repository": {
    "type": "git",
    "url": "https://git.marketally.com/ai-manifests/adp-agent",
    "directory": "packages/agent-anchor"
  },
  "dependencies": {
    "@cityofzion/neon-js": "^5.8.1",
    "adp-agent": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
